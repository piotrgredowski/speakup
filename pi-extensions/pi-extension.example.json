{
  "enabled": true,
  "command": "uvx",
  "args": ["--from", "git+https://github.com/piotrgredowski/let-me-know-agent", "let-me-know-pi", "--config", "/Users/you/.config/let-me-know-agent/config.json"],
  "onlyAssistant": true,
  "summaryMode": "internal",
  "headlessSummary": {
    "command": "pi",
    "args": ["headless", "--model", "{model}", "--prompt", "{prompt}"],
    "model": "default",
    "maxChars": 220,
    "promptTemplate": "Summarize this agent message for spoken notification in <= {maxChars} characters. Return only the summary text.\n\nEvent: {event}\n\nMessage:\n{text}"
  }
}
