{
  "description": "Speak spoken notifications for Droid lifecycle events",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${DROID_PLUGIN_ROOT}/hooks/speakup-hook.py\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUser|ExitSpecMode",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${DROID_PLUGIN_ROOT}/hooks/speakup-hook.py\"",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${DROID_PLUGIN_ROOT}/hooks/speakup-hook.py\"",
            "timeout": 2
          }
        ]
      }
    ]
  }
}