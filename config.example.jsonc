{
  "playback": {
    "queue_enabled": true
  },
  "privacy": {
    "mode": "prefer_local",
    "allow_remote_fallback": true
  },
  "events": {
    "speak_on_final": true,
    "speak_on_error": true,
    "speak_on_needs_input": true,
    "speak_on_progress": true
  },
  "event_sounds": {
    "enabled": true,
    "files": {
      "final": "/System/Library/Sounds/Glass.aiff",
      "error": "/System/Library/Sounds/Basso.aiff",
      "needs_input": "/System/Library/Sounds/Funk.aiff",
      "progress": "/System/Library/Sounds/Pop.aiff",
      "info": "/System/Library/Sounds/Ping.aiff"
    }
  },
  "summarization": {
    "max_chars": 500,
    "provider_order": [
      "cerebras",
      "openai",
      "lmstudio",
      "command",
      "rule_based"
    ]
  },
  "fallback": {
    "fail_fast": false
  },
  "tts": {
    "provider_order": [
      "omlx",
      "macos",
      "lmstudio",
      "elevenlabs",
      "openai"
    ],
    "voice": "default",
    "speed": 1.0,
    "session_name_speed": null,
    "message_speed": null,
    "play_audio": true,
    "audio_format": "wav",
    "save_audio_dir": "/tmp/speakup/audio"
  },
  "session_naming": {
    "enabled": true
  },
  "dedup": {
    "enabled": true,
    "window_seconds": 30,
    "cache_file": "/tmp/speakup/last_progress.json"
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "format": "text",
    "destination": [
      "stderr"
    ],
    "file_path": "~/Library/Logs/speakup/speakup.log",
    "file_path_color": "~/Library/Logs/speakup/speakup.color.log",
    "rotate_max_bytes": 1048576,
    "rotate_backup_count": 3,
    "include_timestamps": true,
    "include_module": true,
    "include_pid": false,
    "log_message_text": false,
    "log_provider_payloads": false,
    "redact_sensitive": true
  },
  "log_viewer": {
    "command": "tail -n 25 -f"
  },
  "config_viewer": {
    "command": null
  },
  "speech_template": {
    "title": {
      "separator": " ",
      "parts": [
        {
          "field": "source_tool",
          "fallback": "agent"
        },
        {
          "text": "from session",
          "when": "session_name"
        },
        {
          "field": "session_name",
          "when": "session_name"
        },
        {
          "text": "says"
        }
      ]
    },
    "message": {
      "separator": " ",
      "parts": [
        {
          "field": "summary"
        }
      ]
    }
  },
  "providers": {
    "lmstudio": {
      "base_url": "http://localhost:1234/v1",
      "model": "local-model",
      "tts_model": "local-tts-model",
      "title_voice": null,
      "message_voice": null
    },
    "elevenlabs": {
      "api_key_env": "ELEVENLABS_API_KEY",
      "voice_id": "",
      "title_voice": null,
      "message_voice": null
    },
    "openai": {
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-4o-mini-tts",
      "summary_model": "gpt-4o-mini",
      "voice": "alloy",
      "title_voice": null,
      "message_voice": null
    },
    "cerebras": {
      "api_key_env": "CEREBRAS_API_KEY",
      "model": "llama3.1-8b",
      "base_url": "https://api.cerebras.ai/v1"
    },
    "gemini": {
      "api_key_env": "GOOGLE_API_KEY",
      "model": "gemini-2.5-flash-preview-tts",
      "voice": "Kore",
      "title_voice": null,
      "message_voice": null
    },
    "omlx": {
      "base_url": "http://127.0.0.1:8000/v1",
      "api_key_env": "OMLX_API_KEY",
      "model": "Kokoro-82M-bf16",
      "voice": "af_heart",
      "title_voice": null,
      "message_voice": null,
      "timeout": 60.0
    },
    "command_summary": {
      "command": "pi",
      "args": [
        "-p",
        "{message}"
      ],
      "timeout_seconds": 30,
      "trim_output": true
    }
  }
}