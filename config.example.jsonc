{
  "playback": {
    "queue_enabled": true,
    "compose_segments": true,
    "compose_lead_in_ms": 120,
    "compose_gap_ms": 60
  },
  "privacy": {
    "mode": "local_only",
    "allow_remote_fallback": false
  },
  "events": {
    "speak_on_final": true,
    "speak_on_error": true,
    "speak_on_needs_input": true,
    "speak_on_progress": true
  },
  "summarization": {
    "max_chars": 220,
    "provider_order": [
      "rule_based"
    ]
  },
  "fallback": {
    "fail_fast": false
  },
  "event_sounds": {
    "enabled": true,
    "files": {
      "final": "/System/Library/Sounds/Glass.aiff",
      "error": "/System/Library/Sounds/Basso.aiff",
      "needs_input": "/System/Library/Sounds/Funk.aiff",
      "progress": "/System/Library/Sounds/Pop.aiff",
      "info": "/System/Library/Sounds/Ping.aiff"
    }
  },
  "tts": {
    "provider_order": [
      "macos"
    ],
    "voice": "default",
    "speed": 1.0,
    "project_overrides": {},
    "session_name_speed": null,
    "message_speed": null,
    "play_audio": true,
    "audio_format": "wav",
    "save_audio_dir": "/tmp/speakup/audio"
  },
  "session_naming": {
    "enabled": true
  },
  "context_naming": {
    "enabled": true,
    "source": "session",
    "spoken_name": null
  },
  "dedup": {
    "enabled": true,
    "window_seconds": 30,
    "cache_file": "/tmp/speakup/last_progress.json",
    "mode": "duplicate",
    "on_skip": "skip"
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "format": "text",
    "destination": [
      "stderr"
    ],
    "file_path": "~/Library/Logs/speakup/speakup.log",
    "file_path_color": null,
    "rotate_max_bytes": 1048576,
    "rotate_backup_count": 3,
    "include_timestamps": true,
    "include_module": true,
    "include_pid": false,
    "log_message_text": false,
    "log_provider_payloads": false,
    "redact_sensitive": true
  },
  "history": {
    "enabled": true,
    "store_messages": false,
    "retention_days": 30
  },
  "log_viewer": {
    "command": "tail -n 25 -f"
  },
  "config_viewer": {
    "command": null
  },
  "speech_template": {
    "title": {
      "separator": " ",
      "parts": [
        {
          "text": null,
          "field": "source_tool",
          "when": null,
          "fallback": "agent"
        },
        {
          "text": "from",
          "field": null,
          "when": "context_name",
          "fallback": null
        },
        {
          "text": null,
          "field": "context_kind",
          "when": "context_name",
          "fallback": null
        },
        {
          "text": null,
          "field": "context_name",
          "when": "context_name",
          "fallback": null
        },
        {
          "text": "says",
          "field": null,
          "when": null,
          "fallback": null
        }
      ]
    },
    "message": {
      "separator": " ",
      "parts": [
        {
          "text": null,
          "field": "summary",
          "when": null,
          "fallback": null
        }
      ]
    }
  },
  "providers": {
    "macos": {
      "voice": "default",
      "title_voice": null,
      "message_voice": null,
      "available_voices": []
    },
    "lmstudio": {
      "base_url": "http://localhost:1234/v1",
      "model": "local-model",
      "tts_model": "local-tts-model",
      "title_voice": null,
      "message_voice": null,
      "available_voices": []
    },
    "edge": {
      "voice": "en-US-AriaNeural",
      "title_voice": null,
      "message_voice": null,
      "available_voices": []
    },
    "elevenlabs": {
      "api_key_env": "ELEVENLABS_API_KEY",
      "voice_id": "",
      "title_voice": null,
      "message_voice": null,
      "available_voices": []
    },
    "openai": {
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-4o-mini-tts",
      "summary_model": "gpt-4o-mini",
      "voice": "alloy",
      "title_voice": null,
      "message_voice": null,
      "available_voices": []
    },
    "cerebras": {
      "api_key_env": "CEREBRAS_API_KEY",
      "model": "llama3.1-8b",
      "base_url": "https://api.cerebras.ai/v1"
    },
    "gemini": {
      "api_key_env": "GOOGLE_API_KEY",
      "model": "gemini-2.5-flash-preview-tts",
      "summary_model": "gemini-2.5-flash",
      "voice": "Kore",
      "title_voice": null,
      "message_voice": null,
      "available_voices": []
    },
    "omlx": {
      "base_url": "http://127.0.0.1:8000/v1",
      "api_key_env": "OMLX_API_KEY",
      "model": "Kokoro-82M-bf16",
      "voice": "af_heart",
      "title_voice": null,
      "message_voice": null,
      "available_voices": [],
      "timeout": 60.0
    },
    "command_summary": {
      "command": "pi",
      "args": [
        "-p",
        "{message}"
      ],
      "timeout_seconds": 30,
      "trim_output": true
    }
  },
  "droid": {
    "enabled": true,
    "events": {
      "notification": true,
      "stop": true,
      "subagent_stop": false,
      "session_start": false
    }
  }
}
